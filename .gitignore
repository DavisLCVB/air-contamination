# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.obsidian
.atl
docs
data/*.parquet

# Base SQLite del Panel 4 (Rol D) — persistencia local de consultas, crece con
# cada demo/uso; no debe versionarse (equivalente a data/*.parquet arriba).
data/consultas.db

# Jupyter
.ipynb_checkpoints/

# Artefactos de modelado (Rol B) — regenerables con:
#   uv run python src/models.py
# Se ignoran los binarios y las figuras (pesados y reproducibles), pero
# models/metrics.json SÍ se versiona: son las métricas auditables del Panel 2
# y del Reporte PDF, y deben poder revisarse sin reentrenar.
#
# rf.pkl / xgb.pkl y las figuras del modelo ganador (rf_classweight) SÍ se
# versionan pese al patrón de arriba: panel_predictivo.py los carga desde
# disco en el deploy de Streamlit Cloud (`_cargar_artefactos`). Sin ellos, el
# panel entrena en caliente sobre ~700k filas dentro del contenedor gratuito
# (1 CPU / ~1GB RAM) y el proceso muere por OOM sin loguear traceback.
# rf_smote.pkl se deja fuera: pesa ~150MB (por encima del límite de 100MB de
# GitHub) y el panel nunca lo carga en runtime, solo aparece en la tabla
# comparativa de metrics.json como referencia del efecto de SMOTE.
models/*.pkl
models/*.joblib
models/*.png
models/figuras/*.png
!models/rf.pkl
!models/xgb.pkl
!models/confusion_matrix.png
!models/rf_classweight_shap_summary.png
!models/rf_classweight_shap_force.png